# Base de données PostgreSQL
POSTGRES_DB="jae_paris"
POSTGRES_USER="jae_user"
POSTGRES_PASSWORD="change-this-local-password"
DATABASE_URL="postgresql://jae_user:change-this-local-password@localhost:5432/jae_paris?schema=public"

# Auth.js (NextAuth v5)
# Générer avec : openssl rand -base64 32
AUTH_SECRET="generate-a-long-random-secret-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Administrateur initial (seeder)
ADMIN_EMAIL="admin@jae-paris.com"
ADMIN_PASSWORD="choose-a-strong-password-of-at-least-12-characters"

# Paiement externe (Lydia / Stripe — configure selon ton fournisseur)
# Pour Stripe Checkout futur :
STRIPE_SECRET_KEY="sk_test_xxx"
STRIPE_WEBHOOK_SECRET="whsec_xxx"

# URL publique du site (utilisée pour les redirections et emails)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
